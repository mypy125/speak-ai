<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>

<?import java.net.URL?>
<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.mygitgor.chatbot.ChatBotController"
      spacing="15"
      style="-fx-background-color: #f5f7fa; -fx-padding: 15;">

    <stylesheets>
        <URL value="@../styles/main.css"/>
    </stylesheets>

    <fx:define>
        <ToggleGroup fx:id="responseModeToggleGroup"/>
    </fx:define>

    <!-- Основной контейнер -->
    <SplitPane dividerPositions="0.7" VBox.vgrow="ALWAYS">

        <!-- ========================================
             ЛЕВАЯ ЧАСТЬ: ЧАТ
             ======================================== -->
        <VBox spacing="10" style="-fx-padding: 10;">

            <!-- Заголовок с логотипом и статусом -->
            <HBox alignment="CENTER_LEFT" spacing="10">
                <VBox spacing="2">
                    <Label text="SpeakAI Репетитор"
                           style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                    <HBox spacing="5" alignment="CENTER_LEFT">
                        <Circle radius="4" fill="#27ae60"/>
                        <Label fx:id="statusLabel" text="✅ Готов к работе"
                               style="-fx-font-size: 11px; -fx-text-fill: #666666;"/>
                    </HBox>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>

                <!-- Кнопки управления (компактные) -->
                <HBox spacing="5" alignment="CENTER_RIGHT">
                    <Button text="⚙️ Speech"
                            onAction="#toggleSpeechPanel"
                            style="-fx-font-weight: bold; -fx-font-size: 13; -fx-text-fill: #2c3e50;">
                        <tooltip><Tooltip text="Настройки распознавания речи"/></tooltip>
                    </Button>

                    <Button text="🎤 TTS"
                            onAction="#toggleTTSPanel"
                            style="-fx-font-weight: bold; -fx-font-size: 13; -fx-text-fill: #2c3e50;">
                        <tooltip><Tooltip text="Настройки озвучки"/></tooltip>
                    </Button>

                    <Button fx:id="historyButton" text="📋 History"
                            onAction="#onShowHistory"
                            style="-fx-font-weight: bold; -fx-font-size: 13; -fx-text-fill: #2c3e50;">
                        <tooltip><Tooltip text="История разговоров"/></tooltip>
                    </Button>
                    <Button fx:id="clearButton" text="🗑️ Clear"
                            onAction="#onClearChat"
                            style="-fx-font-weight: bold; -fx-font-size: 13; -fx-text-fill: #2c3e50;">
                        <tooltip><Tooltip text="Очистить чат"/></tooltip>
                    </Button>
                </HBox>
            </HBox>

            <!-- Выпадающая панель TTS -->
            <VBox fx:id="ttsControlPanel" visible="false" managed="false" spacing="10"
                  styleClass="card">

                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="🎤 Настройки озвучки (TTS)"
                           styleClass="label-title"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="✕"
                            onAction="#toggleTTSPanel"
                            style="-fx-background-color: transparent; -fx-text-fill: #666666; -fx-font-size: 12px;">
                        <tooltip><Tooltip text="Скрыть настройки озвучки"/></tooltip>
                    </Button>
                </HBox>

                <GridPane hgap="10" vgap="8">
                    <columnConstraints>
                        <ColumnConstraints halignment="RIGHT" minWidth="120" prefWidth="120"/>
                        <ColumnConstraints halignment="LEFT" hgrow="ALWAYS"/>
                    </columnConstraints>

                    <!-- Текущий режим -->
                    <Label text="Текущий режим:" GridPane.rowIndex="0" GridPane.columnIndex="0"
                           style="-fx-text-fill: #666666; -fx-font-weight: 600;"/>
                    <HBox spacing="5" GridPane.rowIndex="0" GridPane.columnIndex="1">
                        <Label fx:id="ttsModeLabel" text="Загрузка..."
                               style="-fx-font-weight: bold; -fx-text-fill: #3498db;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <HBox spacing="5" alignment="CENTER_RIGHT">
                            <Circle fx:id="ttsStatusIndicator" radius="4" fill="#95a5a6"/>
                            <Label fx:id="ttsStatusLabel" text="Статус..."
                                   style="-fx-font-size: 11px; -fx-text-fill: #666666;"/>
                        </HBox>
                    </HBox>

                    <!-- Кнопки управления -->
                    <Label text="Действия:" GridPane.rowIndex="1" GridPane.columnIndex="0"
                           style="-fx-text-fill: #666666; -fx-font-weight: 600;"/>
                    <HBox spacing="10" GridPane.rowIndex="1" GridPane.columnIndex="1">
                        <Button text="🔊 Тест TTS"
                                onAction="#onTestTTS"
                                style="-fx-background-color: #2ecc71; -fx-text-fill: white;
                                       -fx-background-radius: 20; -fx-padding: 6 12;"
                                maxWidth="Infinity" HBox.hgrow="ALWAYS">
                            <tooltip>
                                <Tooltip text="Протестировать текущий режим озвучки"/>
                            </tooltip>
                        </Button>
                    </HBox>

                    <!-- Информация о режиме -->
                    <Label text="Описание:" GridPane.rowIndex="2" GridPane.columnIndex="0"
                           style="-fx-text-fill: #666666; -fx-font-weight: 600;"/>
                    <VBox spacing="5" GridPane.rowIndex="2" GridPane.columnIndex="1">
                        <TextArea fx:id="ttsInfoTextArea"
                                  editable="false"
                                  wrapText="true"
                                  prefRowCount="4"
                                  style="-fx-font-size: 11px; -fx-background-color: #f8f9fa;
                                         -fx-border-color: #e0e0e0; -fx-border-radius: 5;"/>
                    </VBox>
                </GridPane>

                <!-- Для Google Cloud TTS: расширенные настройки (видно только в режиме Google Cloud) -->
                <VBox fx:id="googleCloudSettings" visible="false" managed="false"
                      spacing="8" style="-fx-padding: 10 0 0 0;">
                    <Label text="⚙️ Настройки Google Cloud TTS" styleClass="label-subtitle"/>

                    <!-- Выбор языка -->
                    <GridPane hgap="10" vgap="8">
                        <columnConstraints>
                            <ColumnConstraints halignment="RIGHT" minWidth="120" prefWidth="120"/>
                            <ColumnConstraints halignment="LEFT" hgrow="ALWAYS"/>
                        </columnConstraints>

                        <Label text="Язык:" GridPane.rowIndex="0" GridPane.columnIndex="0"
                               style="-fx-text-fill: #666666; -fx-font-weight: 600;"/>
                        <HBox spacing="5" GridPane.rowIndex="0" GridPane.columnIndex="1">
                            <ComboBox fx:id="googleLanguageComboBox"
                                      prefWidth="200"
                                      promptText="Выберите язык..."/>
                            <Region HBox.hgrow="ALWAYS"/>
                        </HBox>

                        <Label text="Голос:" GridPane.rowIndex="1" GridPane.columnIndex="0"
                               style="-fx-text-fill: #666666; -fx-font-weight: 600;"/>
                        <HBox spacing="5" GridPane.rowIndex="1" GridPane.columnIndex="1">
                            <ComboBox fx:id="googleVoiceComboBox"
                                      prefWidth="300"
                                      promptText="Выберите голос..."/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label fx:id="googleVoiceDescriptionLabel" text=""
                                   style="-fx-font-size: 11px; -fx-text-fill: #95a5a6;"/>
                        </HBox>
                    </GridPane>

                    <!-- Настройки качества звука -->
                    <GridPane hgap="10" vgap="8" style="-fx-padding: 10 0 0 0;">
                        <columnConstraints>
                            <ColumnConstraints halignment="RIGHT" minWidth="120" prefWidth="120"/>
                            <ColumnConstraints halignment="LEFT" hgrow="ALWAYS"/>
                        </columnConstraints>

                        <!-- Скорость -->
                        <Label text="Скорость:" GridPane.rowIndex="0" GridPane.columnIndex="0"
                               style="-fx-text-fill: #666666; -fx-font-weight: 600;"/>
                        <VBox spacing="5" GridPane.rowIndex="0" GridPane.columnIndex="1">
                            <HBox spacing="10" alignment="CENTER_LEFT">
                                <Slider fx:id="googleSpeedSlider" prefWidth="150"
                                        min="0.25" max="4.0" value="1.0" HBox.hgrow="ALWAYS"/>
                                <Label fx:id="googleSpeedLabel" text="1.0x"
                                       style="-fx-font-weight: bold; -fx-text-fill: #3498db; -fx-min-width: 40;"/>
                            </HBox>
                            <HBox spacing="5">
                                <Label text="Медленно (0.25x)" styleClass="label-hint"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Label text="Быстро (4.0x)" styleClass="label-hint"/>
                            </HBox>
                        </VBox>

                        <!-- Тон -->
                        <Label text="Тон голоса:" GridPane.rowIndex="1" GridPane.columnIndex="0"
                               style="-fx-text-fill: #666666; -fx-font-weight: 600;"/>
                        <VBox spacing="5" GridPane.rowIndex="1" GridPane.columnIndex="1">
                            <HBox spacing="10" alignment="CENTER_LEFT">
                                <Slider fx:id="googlePitchSlider" prefWidth="150"
                                        min="-20.0" max="20.0" value="0.0" HBox.hgrow="ALWAYS"/>
                                <Label fx:id="pitchLabel" text="0.0"
                                       style="-fx-font-weight: bold; -fx-text-fill: #9b59b6; -fx-min-width: 40;"/>
                            </HBox>
                            <HBox spacing="5">
                                <Label text="Низкий (-20)" styleClass="label-hint"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Label text="Высокий (20)" styleClass="label-hint"/>
                            </HBox>
                        </VBox>

                        <!-- Громкость -->
                        <Label text="Громкость:" GridPane.rowIndex="2" GridPane.columnIndex="0"
                               style="-fx-text-fill: #666666; -fx-font-weight: 600;"/>
                        <VBox spacing="5" GridPane.rowIndex="2" GridPane.columnIndex="1">
                            <HBox spacing="10" alignment="CENTER_LEFT">
                                <Slider fx:id="googleVolumeSlider" prefWidth="150"
                                        min="-96.0" max="16.0" value="0.0" HBox.hgrow="ALWAYS"/>
                                <Label fx:id="volumeLabel" text="0 дБ"
                                       style="-fx-font-weight: bold; -fx-text-fill: #e67e22; -fx-min-width: 40;"/>
                            </HBox>
                            <HBox spacing="5">
                                <Label text="Тише (-96 дБ)" styleClass="label-hint"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Label text="Громче (16 дБ)" styleClass="label-hint"/>
                            </HBox>
                        </VBox>
                    </GridPane>

                    <!-- Кнопки управления Google Cloud TTS -->
                    <HBox spacing="10" alignment="CENTER" style="-fx-padding: 10 0 0 0;">
                        <Button fx:id="testGoogleTTSButton" text="🔊 Тест Google TTS"
                                onAction="#onTestGoogleTTS"
                                style="-fx-background-color: #4285f4; -fx-text-fill: white;
                                       -fx-background-radius: 20; -fx-padding: 6 12;"
                                maxWidth="Infinity" HBox.hgrow="ALWAYS">
                            <tooltip><Tooltip text="Тестирование Google Cloud TTS с текущими настройками"/></tooltip>
                        </Button>

                        <Button fx:id="showTTSInfoButton" text="ℹ️ Информация"
                                onAction="#onShowTTSInfo"
                                style="-fx-background-color: #7f8c8d; -fx-text-fill: white;
                                       -fx-background-radius: 20; -fx-padding: 6 12;"
                                maxWidth="Infinity" HBox.hgrow="ALWAYS">
                            <tooltip><Tooltip text="Показать информацию о текущем TTS сервисе"/></tooltip>
                        </Button>

                        <Button fx:id="configureGoogleTTSButton" text="⚙️ Настройки"
                                onAction="#onConfigureGoogleTTS"
                                style="-fx-background-color: #95a5a6; -fx-text-fill: white;
                                       -fx-background-radius: 20; -fx-padding: 6 12;"
                                maxWidth="Infinity" HBox.hgrow="ALWAYS">
                            <tooltip><Tooltip text="Инструкции по настройке Google Cloud TTS"/></tooltip>
                        </Button>
                    </HBox>
                </VBox>

                <!-- Для OpenAI TTS: выбор голоса (видно только в режиме OpenAI) -->
                <VBox fx:id="openaiVoiceSettings" visible="false" managed="false"
                      spacing="5" style="-fx-padding: 10 0 0 0;">
                    <Label text="🎤 Настройки OpenAI/Groq TTS" styleClass="label-subtitle"/>

                    <GridPane hgap="10" vgap="8">
                        <columnConstraints>
                            <ColumnConstraints halignment="RIGHT" minWidth="120" prefWidth="120"/>
                            <ColumnConstraints halignment="LEFT" hgrow="ALWAYS"/>
                        </columnConstraints>

                        <!-- Выбор голоса -->
                        <Label text="Голос:" GridPane.rowIndex="0" GridPane.columnIndex="0"
                               style="-fx-text-fill: #666666; -fx-font-weight: 600;"/>
                        <HBox spacing="10" GridPane.rowIndex="0" GridPane.columnIndex="1">
                            <ComboBox fx:id="voiceComboBox"
                                      prefWidth="200"
                                      promptText="Выберите голос..."/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label fx:id="voiceDescriptionLabel" text=""
                                   style="-fx-font-size: 11px; -fx-text-fill: #95a5a6;"/>
                        </HBox>

                        <!-- Скорость речи -->
                        <Label text="Скорость:" GridPane.rowIndex="1" GridPane.columnIndex="0"
                               style="-fx-text-fill: #666666; -fx-font-weight: 600;"/>
                        <VBox spacing="5" GridPane.rowIndex="1" GridPane.columnIndex="1">
                            <HBox spacing="10" alignment="CENTER_LEFT">
                                <Slider fx:id="speechSpeedSlider" prefWidth="150"
                                        min="0.5" max="2.0" value="1.0" HBox.hgrow="ALWAYS"/>
                                <Label fx:id="speedLabel" text="1.0x"
                                       style="-fx-font-weight: bold; -fx-text-fill: #3498db; -fx-min-width: 40;"/>
                            </HBox>
                            <HBox spacing="5">
                                <Label text="Медленно" styleClass="label-hint"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Label text="Быстро" styleClass="label-hint"/>
                            </HBox>
                        </VBox>
                    </GridPane>

                    <!-- Кнопки управления OpenAI TTS -->
                    <HBox spacing="10" alignment="CENTER" style="-fx-padding: 10 0 0 0;">
                        <Button text="🔊 Тест OpenAI TTS"
                                onAction="#onTestTTS"
                                style="-fx-background-color: #10a37f; -fx-text-fill: white;
                                       -fx-background-radius: 20; -fx-padding: 6 12;"
                                maxWidth="Infinity" HBox.hgrow="ALWAYS">
                            <tooltip><Tooltip text="Тестирование OpenAI/Groq TTS"/></tooltip>
                        </Button>
                    </HBox>
                </VBox>

                <!-- Для демо-режима: настройка скорости вывода -->
                <VBox fx:id="demoSettings" visible="false" managed="false"
                      spacing="5" style="-fx-padding: 10 0 0 0;">
                    <Label text="🎭 Настройки демо-режима" styleClass="label-subtitle"/>

                    <GridPane hgap="10" vgap="8">
                        <columnConstraints>
                            <ColumnConstraints halignment="RIGHT" minWidth="120" prefWidth="120"/>
                            <ColumnConstraints halignment="LEFT" hgrow="ALWAYS"/>
                        </columnConstraints>

                        <Label text="Скорость печати:" GridPane.rowIndex="0" GridPane.columnIndex="0"
                               style="-fx-text-fill: #666666; -fx-font-weight: 600;"/>
                        <VBox spacing="5" GridPane.rowIndex="0" GridPane.columnIndex="1">
                            <HBox spacing="10" alignment="CENTER_LEFT">
                                <Slider fx:id="typingSpeedSlider" prefWidth="150"
                                        min="50" max="500" value="200" HBox.hgrow="ALWAYS"/>
                                <Label fx:id="typingSpeedLabel" text="200 мс/слово"
                                       style="-fx-font-weight: bold; -fx-text-fill: #3498db; -fx-min-width: 100;"/>
                            </HBox>
                            <HBox spacing="5">
                                <Label text="Медленно" styleClass="label-hint"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Label text="Быстро" styleClass="label-hint"/>
                            </HBox>
                        </VBox>
                    </GridPane>

                    <HBox spacing="10" alignment="CENTER" style="-fx-padding: 10 0 0 0;">
                        <Button text="🔊 Тест демо-режима"
                                onAction="#onTestTTS"
                                style="-fx-background-color: #f39c12; -fx-text-fill: white;
                                       -fx-background-radius: 20; -fx-padding: 6 12;"
                                maxWidth="Infinity" HBox.hgrow="ALWAYS">
                            <tooltip><Tooltip text="Тестирование демо-режима (вывод в консоль)"/></tooltip>
                        </Button>
                    </HBox>
                </VBox>
            </VBox>

            <!-- Выпадающая панель распознавания речи -->
            <VBox fx:id="speechControlPanel" visible="false" managed="false" spacing="10"
                  styleClass="card">

                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="🎤 Настройки распознавания речи (STT)"
                           styleClass="label-title"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="✕"
                            onAction="#toggleSpeechPanel"
                            style="-fx-background-color: transparent; -fx-text-fill: #666666; -fx-font-size: 12px;">
                        <tooltip><Tooltip text="Скрыть настройки распознавания"/></tooltip>
                    </Button>
                </HBox>

                <GridPane hgap="10" vgap="8">
                    <columnConstraints>
                        <ColumnConstraints halignment="RIGHT" minWidth="120" prefWidth="120"/>
                        <ColumnConstraints halignment="LEFT" hgrow="ALWAYS"/>
                    </columnConstraints>

                    <Label text="Сервис:" GridPane.rowIndex="0" GridPane.columnIndex="0"
                           style="-fx-text-fill: #666666; -fx-font-weight: 600;"/>
                    <ComboBox fx:id="serviceTypeComboBox" GridPane.rowIndex="0" GridPane.columnIndex="1"
                              maxWidth="Infinity"/>

                    <Label text="Язык:" GridPane.rowIndex="1" GridPane.columnIndex="0"
                           style="-fx-text-fill: #666666; -fx-font-weight: 600;"/>
                    <ComboBox fx:id="languageComboBox" GridPane.rowIndex="1" GridPane.columnIndex="1"
                              maxWidth="Infinity"/>

                    <Label text="Чувствительность:" GridPane.rowIndex="2" GridPane.columnIndex="0"
                           style="-fx-text-fill: #666666; -fx-font-weight: 600;"/>
                    <VBox spacing="5" GridPane.rowIndex="2" GridPane.columnIndex="1">
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Slider fx:id="microphoneSensitivitySlider" prefWidth="200"
                                    min="0.1" max="1.0" value="0.5" HBox.hgrow="ALWAYS"/>
                            <Label fx:id="sensitivityLabel" text="0.5"
                                   style="-fx-font-weight: bold; -fx-text-fill: #3498db; -fx-min-width: 30;"/>
                        </HBox>
                        <HBox spacing="5">
                            <Label text="Низкая" styleClass="label-hint"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label text="Высокая" styleClass="label-hint"/>
                        </HBox>
                    </VBox>
                </GridPane>

                <HBox spacing="10" alignment="CENTER">
                    <Button fx:id="testMicrophoneButton" text="🎤 Тест микрофона"
                            onAction="#testMicrophone"
                            styleClass="button-primary">
                        <tooltip><Tooltip text="Тестирование работы микрофона"/></tooltip>
                    </Button>

                    <Button fx:id="testSpeechButton" text="🔊 Тест распознавания"
                            onAction="#testSpeechRecognition"
                            styleClass="button-info">
                        <tooltip><Tooltip text="Тестирование распознавания речи"/></tooltip>
                    </Button>
                </HBox>

                <HBox spacing="10" alignment="CENTER_LEFT"
                      styleClass="panel">
                    <Label fx:id="speechServiceStatusLabel" text="Готов к работе"
                           styleClass="label-subtitle"/>
                </HBox>
            </VBox>

            <!-- Область чата -->
            <VBox spacing="5" VBox.vgrow="ALWAYS" styleClass="card">
                <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-padding: 0 0 10 0;">
                    <Label text="💬 Диалог с ИИ-репетитором" styleClass="label-title"/>
                </HBox>

                <!-- Контейнер для сообщений -->
                <ScrollPane fx:id="chatScrollPane"
                            fitToWidth="true"
                            style="-fx-background-color: transparent; -fx-border-color: transparent;"
                            hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                            VBox.vgrow="ALWAYS">
                    <VBox fx:id="chatMessagesContainer"
                          spacing="12"
                          style="-fx-padding: 10;"/>
                </ScrollPane>

                <!-- ToggleGroup и режимы ответа -->
                <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-padding: 10 0 0 0;">
                    <Label text="Режим ответа:" style="-fx-font-size: 12px; -fx-text-fill: #666;"/>

                    <ToggleButton text="📝 Текст"
                                  fx:id="textToggle"
                                  userData="TEXT"
                                  toggleGroup="$responseModeToggleGroup"
                                  selected="true"
                                  style="-fx-font-size: 12px;"/>

                    <ToggleButton text="🔊 Голос"
                                  fx:id="voiceToggle"
                                  userData="VOICE"
                                  toggleGroup="$responseModeToggleGroup"
                                  style="-fx-font-size: 12px;"/>

                    <Button fx:id="playResponseButton"
                            text="▶️"
                            style="-fx-font-size: 12px;"
                            onAction="#onPlayResponse"
                            visible="false"
                            managed="false"/>
                </HBox>
            </VBox>

            <!-- Панель ввода -->
            <VBox spacing="8" styleClass="panel">
                <HBox spacing="5" alignment="CENTER_LEFT">
                    <Circle radius="6" fill="#3498db"/>
                    <Label text="Ваше сообщение"
                           style="-fx-font-size: 12px; -fx-font-weight: 600; -fx-text-fill: #3498db;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <HBox spacing="5" alignment="CENTER_RIGHT">
                        <ProgressIndicator fx:id="recordingIndicator" visible="false"
                                           style="-fx-pref-width: 16; -fx-pref-height: 16;"/>
                        <Label fx:id="recordingTimeLabel" text="00:00"
                               style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #e74c3c;"/>
                    </HBox>
                </HBox>

                <HBox spacing="5" alignment="CENTER">
                    <TextArea fx:id="inputField"
                              promptText="Напишите сообщение на английском или запишите голос..."
                              wrapText="true"
                              prefRowCount="2"
                              HBox.hgrow="ALWAYS"
                              style="-fx-font-size: 13px;"/>

                    <Button fx:id="microphoneButton" text="🎤"
                            onAction="#onMicrophoneRecognition"
                            styleClass="button-round,button-info"
                            style="-fx-margin: 0 0 0 5;">
                        <tooltip><Tooltip text="Распознавание речи в текст"/></tooltip>
                    </Button>
                </HBox>

                <HBox spacing="8" alignment="CENTER">
                    <Button fx:id="recordButton" text="● Запись"
                            onAction="#onStartRecording"
                            styleClass="button-danger"
                            style="-fx-background-radius: 20; -fx-padding: 8 15;"/>

                    <Button fx:id="stopButton" text="⏹️ Стоп"
                            onAction="#onStopRecording"
                            styleClass="button-secondary"
                            style="-fx-background-radius: 20; -fx-padding: 8 15;"
                            disable="true"/>

                    <Region HBox.hgrow="ALWAYS"/>

                    <HBox spacing="5" alignment="CENTER">
                        <Button fx:id="analyzeButton" text="📊"
                                onAction="#onAnalyzeAudio"
                                styleClass="button-round,button-primary"
                                disable="true">
                            <tooltip><Tooltip text="Анализ аудио"/></tooltip>
                        </Button>

                        <Button fx:id="pronunciationButton" text="🗣️"
                                onAction="#onPronunciationTraining"
                                styleClass="button-round,button-success"
                                disable="true">
                            <tooltip><Tooltip text="Тренажер произношения"/></tooltip>
                        </Button>
                    </HBox>

                    <Region HBox.hgrow="ALWAYS"/>

                    <Button fx:id="sendButton" text="Отправить ➤"
                            onAction="#onSendMessage"
                            styleClass="button-success"
                            style="-fx-background-radius: 20; -fx-padding: 8 20;"/>
                </HBox>

                <ProgressBar fx:id="analysisProgress" visible="false"
                             style="-fx-pref-height: 4px;"/>
            </VBox>
        </VBox>

        <!-- ========================================
             ПРАВАЯ ЧАСТЬ: АНАЛИЗ И РЕКОМЕНДАЦИИ
             ======================================== -->
        <VBox spacing="10" style="-fx-padding: 10;">

            <!-- Заголовок анализа -->
            <HBox spacing="10" alignment="CENTER_LEFT" styleClass="card">
                <StackPane>
                    <Circle radius="16" fill="#3498db"/>
                    <Label text="📊" style="-fx-text-fill: white; -fx-font-size: 12px;"/>
                </StackPane>
                <VBox spacing="2">
                    <Label text="Анализ речи" styleClass="label-title"/>
                    <Label text="Оценка вашего произношения" styleClass="label-subtitle"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="phonemeLabel" text="" visible="false"
                       styleClass="badge,badge-warning"/>
            </HBox>

            <!-- Вкладки анализа -->
            <TabPane tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">
                <Tab text="📋 Кратко">
                    <VBox VBox.vgrow="ALWAYS">
                        <TextArea fx:id="analysisArea"
                                  editable="false"
                                  wrapText="true"
                                  VBox.vgrow="ALWAYS"
                                  style="-fx-font-family: 'Segoe UI', sans-serif;
                             -fx-font-size: 12px;
                             -fx-background-color: transparent;
                             -fx-border-color: transparent;
                             -fx-padding: 12;"/>
                    </VBox>
                </Tab>

                <Tab text="📈 Детально">
                    <VBox VBox.vgrow="ALWAYS">
                        <TextArea fx:id="detailedAnalysisArea"
                                  editable="false"
                                  wrapText="true"
                                  VBox.vgrow="ALWAYS"
                                  style="-fx-font-family: 'Consolas', monospace;
                             -fx-font-size: 11px;
                             -fx-background-color: transparent;
                             -fx-border-color: transparent;
                             -fx-padding: 12;"/>
                    </VBox>
                </Tab>

                <Tab text="💡 Советы">
                    <VBox VBox.vgrow="ALWAYS">
                        <TextArea fx:id="recommendationsArea"
                                  editable="false"
                                  wrapText="true"
                                  VBox.vgrow="ALWAYS"
                                  style="-fx-font-family: 'Segoe UI', sans-serif;
                             -fx-font-size: 12px;
                             -fx-background-color: transparent;
                             -fx-border-color: transparent;
                             -fx-padding: 12;"/>
                    </VBox>
                </Tab>
            </TabPane>

            <!-- Статистика и быстрые действия -->
            <VBox spacing="8" styleClass="card">
                <Label text="📊 Статистика сессии" styleClass="label-title"/>

                <GridPane hgap="10" vgap="5">
                    <columnConstraints>
                        <ColumnConstraints halignment="LEFT" hgrow="SOMETIMES"/>
                        <ColumnConstraints halignment="RIGHT" hgrow="SOMETIMES"/>
                    </columnConstraints>

                    <Label text="Сообщения:" GridPane.rowIndex="0" GridPane.columnIndex="0"
                           styleClass="label-hint"/>
                    <Label fx:id="messagesCountLabel" text="0" GridPane.rowIndex="0" GridPane.columnIndex="1"
                           style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #3498db;"/>

                    <Label text="Анализы:" GridPane.rowIndex="1" GridPane.columnIndex="0"
                           styleClass="label-hint"/>
                    <Label fx:id="analysisCountLabel" text="0" GridPane.rowIndex="1" GridPane.columnIndex="1"
                           style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #27ae60;"/>

                    <Label text="Записи:" GridPane.rowIndex="2" GridPane.columnIndex="0"
                           styleClass="label-hint"/>
                    <Label fx:id="recordingsCountLabel" text="0" GridPane.rowIndex="2" GridPane.columnIndex="1"
                           style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #f39c12;"/>
                </GridPane>

                <Separator style="-fx-padding: 5 0;"/>

                <HBox spacing="8" alignment="CENTER">
                    <Button text="⚙️"
                            onAction="#onSettings"
                            styleClass="button-round,button-secondary">
                        <tooltip><Tooltip text="Настройки"/></tooltip>
                    </Button>

                    <Button text="❓"
                            onAction="#onHelp"
                            styleClass="button-round,button-warning">
                        <tooltip><Tooltip text="Помощь"/></tooltip>
                    </Button>

                    <Region HBox.hgrow="ALWAYS"/>

                    <VBox spacing="2" alignment="CENTER_RIGHT">
                        <Label text="💡 Совет дня" styleClass="label-hint"/>
                        <Label text="Регулярная практика = прогресс"
                               style="-fx-font-size: 9px; -fx-text-fill: #95a5a6;"/>
                    </VBox>
                </HBox>
            </VBox>
        </VBox>
    </SplitPane>
</VBox>